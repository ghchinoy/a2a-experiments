# A2A Simple Example - Environment Variables

# --- Google Cloud Platform Settings ---
# Your GCP Project ID (used for Vertex AI backend)
GOOGLE_CLOUD_PROJECT=your-project-id

# GCP Region (e.g., us-central1)
GOOGLE_CLOUD_LOCATION=us-central1

# --- Gemini Model Settings ---
# The default model to use for greetings and summarization
# Options: gemini-3-flash-preview, gemini-2.5-flash, etc.
GEMINI_MODEL=gemini-3-flash-preview

# --- Gemini Interactions API Settings ---
# Required for the ai_researcher and stateful chat skills.
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-api-key-here
